<!DOCTYPE html>
<html lang="{{ page.lang }}">
<head>
  {{ partial('_partials/head/head.njk', {}, {cache: theme.cache.enable}) }}
  {%- include '_partials/head/head-unique.njk' -%}
  <title>{% block title %}{% endblock %}</title>
  {{ partial('_third-party/analytics/index.njk', {}, {cache: theme.cache.enable}) }}
  {{ partial('_scripts/index.njk', {}, {cache: theme.cache.enable}) }}
  {{ partial('_third-party/index.njk', {}, {cache: theme.cache.enable}) }}
  {{ partial('_third-party/statistics/index.njk', {}, {cache: theme.cache.enable}) }}
  {%- include '_third-party/math/index.njk' -%}
  {%- include '_third-party/quicklink.njk' -%}
  {{- next_inject('head') }}
  <noscript>
    <link rel="stylesheet" href="{{ url_for(theme.css) }}/noscript.css">
  </noscript>
</head>

<body itemscope itemtype="http://schema.org/WebPage"{% if theme.motion.enable %} class="use-motion"{% endif %}>
  <div class="headband"></div>

  <main class="main">
    <div class="column">
      <header class="header" itemscope itemtype="http://schema.org/WPHeader">
        {%- include '_partials/header/index.njk' -%}
      </header>
      {%- if theme.sidebar.display !== 'remove' %}
        {% block sidebar %}{% endblock %}
      {%- endif %}
    </div>

    <div class="main-inner {% block class %}{% endblock %}">
      {%- include '_partials/header/sub-menu.njk' -%}
      {% block content %}{% endblock %}
      {%- include '_partials/comments.njk' -%}
    </div>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      {%- include '_partials/languages.njk' -%}
      {{ partial('_partials/footer.njk', {}, {cache: theme.cache.enable}) }}
    </div>
  </footer>

  {{ partial('_partials/widgets.njk', {}, {cache: theme.cache.enable}) }}

  {{- next_inject('bodyEnd') }}
  <style>
/* ── World-Class Cosmic Sea Theme ── */
html, body {
  background: linear-gradient(160deg, #050d14 0%, #071820 25%, #0a2030 50%, #071418 75%, #050d14 100%) !important;
  background-attachment: fixed !important;
  min-height: 100vh !important;
}
/* Sea image overlay */
html::before {
  content: ''; position: fixed; inset: 0; z-index: 0;
  background: url('/images/hero-assets/sea-reference.jpg') center / cover no-repeat fixed;
  opacity: .38; mix-blend-mode: screen; pointer-events: none;
  filter: saturate(.75) contrast(1.08) brightness(.92);
}
/* Subtle noise grain */
html::after {
  content: ''; position: fixed; inset: 0; z-index: 1; pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");
  opacity: .45; mix-blend-mode: overlay;
}
body { position: relative; z-index: 2; background: transparent !important; }

/* ── Header ── */
.header, header {
  background: rgba(5, 13, 20, .88) !important;
  backdrop-filter: blur(24px) saturate(1.5) !important;
  border-bottom: 1px solid rgba(168, 217, 189, .18) !important;
  box-shadow: 0 4px 40px rgba(0,0,0,.5), 0 1px 0 rgba(168,217,189,.08) inset !important;
}
.site-title, .site-name {
  font-family: "Noto Serif SC", "Songti SC", serif !important;
  color: rgba(255, 255, 255, .97) !important;
  letter-spacing: .18em !important;
  text-shadow: 0 0 30px rgba(168,217,189,.35), 0 2px 8px rgba(0,0,0,.6) !important;
  font-size: 1.15em !important;
}
.menu-item a, header nav a {
  color: rgba(255, 255, 255, .82) !important;
  letter-spacing: .1em !important;
  font-family: ui-monospace, SFMono-Regular, Consolas, monospace !important;
  font-size: .82em !important;
  transition: color .3s ease, text-shadow .3s ease !important;
}
.menu-item a:hover, header nav a:hover {
  color: rgba(255, 255, 255, 1) !important;
  text-shadow: 0 0 22px rgba(168, 217, 189, .8), 0 0 40px rgba(168,217,189,.3) !important;
}

/* ── Content Wrap ── */
.content-wrap {
  background: rgba(5, 13, 20, .55) !important;
  backdrop-filter: blur(20px) saturate(1.3) !important;
  border-radius: 24px !important;
  border: 1px solid rgba(168, 217, 189, .1) !important;
  box-shadow: 0 8px 64px rgba(0,0,0,.4), 0 0 0 1px rgba(255,255,255,.03) inset !important;
  margin: 32px auto !important;
  max-width: 860px !important;
}

/* ── Post Block Cards ── */
.post-block, .posts-expand .post {
  background: rgba(10, 32, 48, .5) !important;
  backdrop-filter: blur(16px) !important;
  border: 1px solid rgba(168, 217, 189, .12) !important;
  border-radius: 20px !important;
  box-shadow: 0 4px 32px rgba(0,0,0,.3), 0 0 40px rgba(168,217,189,.04) !important;
  margin: 28px !important;
  padding: 36px 40px !important;
  transition: border-color .35s ease, box-shadow .35s ease, transform .35s ease !important;
}
.post-block:hover, .posts-expand .post:hover {
  border-color: rgba(168, 217, 189, .32) !important;
  box-shadow: 0 8px 48px rgba(0,0,0,.4), 0 0 60px rgba(168,217,189,.1) !important;
  transform: translateY(-2px) !important;
}

/* ── Post Title ── */
.posts-expand .post-title a, .posts-expand .post-title {
  font-family: "Noto Serif SC", serif !important;
  color: rgba(255, 255, 255, .97) !important;
  font-size: 1.45em !important;
  font-weight: 400 !important;
  letter-spacing: .1em !important;
  text-shadow: 0 2px 12px rgba(0,0,0,.5) !important;
  transition: color .25s ease !important;
}
.posts-expand .post-title a:hover {
  color: rgba(255, 255, 255, 1) !important;
  text-shadow: 0 0 20px rgba(168,255,200,.5) !important;
}

/* ── Post Meta ── */
.posts-expand .post-meta {
  color: rgba(255, 255, 255, .85) !important;
  font-family: ui-monospace, SFMono-Regular, Consolas, monospace !important;
  font-size: .75em !important;
  letter-spacing: .15em !important;
  text-transform: uppercase !important;
  margin-top: 10px !important;
}

/* ── Archive Timeline ── */
.posts-collapse { margin-left: 2px !important; }
.posts-collapse .post-header { padding-left: 28px !important; position: relative !important; }
.posts-collapse .post-header::before {
  content: ''; position: absolute !important;
  left: 6px !important; top: 18px !important;
  width: 10px !important; height: 10px !important;
  background: rgba(168, 217, 189, .5) !important;
  border: 2px solid rgba(168, 217, 189, .3) !important;
  border-radius: 50% !important;
  box-shadow: 0 0 14px rgba(168, 217, 189, .5), 0 0 28px rgba(168,217,189,.2) !important;
  z-index: 2 !important;
  transition: all .3s ease !important;
}
.posts-collapse .post-item:hover .post-header::before {
  background: rgba(168, 255, 200, .9) !important;
  box-shadow: 0 0 20px rgba(168,255,200,.8), 0 0 40px rgba(168,255,200,.3) !important;
}
.posts-collapse .post-items::before {
  content: ''; position: absolute !important;
  left: 10px !important; top: 0; bottom: 0 !important;
  width: 1px !important;
  background: linear-gradient(to bottom, rgba(168,217,189,.5), rgba(168,217,189,.05)) !important;
  box-shadow: 0 0 8px rgba(168,217,189,.2) !important;
}
.posts-collapse .post-item {
  padding: 14px 0 !important;
  border-radius: 14px !important;
  transition: background .3s ease !important;
  margin-bottom: 4px !important;
}
.posts-collapse .post-item:hover { background: rgba(168, 217, 189, .05) !important; }
.posts-collapse .post-title a {
  font-family: "Noto Serif SC", serif !important;
  color: rgba(255, 255, 255, .95) !important;
  font-size: 1.15em !important;
  letter-spacing: .08em !important;
  transition: color .25s ease !important;
}
.posts-collapse .post-title a:hover { color: rgba(255, 255, 255, 1) !important; }

/* ── Page Title ── */
.page-title {
  font-family: "Noto Serif SC", serif !important;
  color: rgba(255, 255, 255, .97) !important;
  text-align: center !important;
  font-size: clamp(28px, 4vw, 48px) !important;
  letter-spacing: .25em !important;
  text-shadow: 0 0 40px rgba(168,217,189,.3), 0 2px 8px rgba(0,0,0,.5) !important;
  margin-bottom: 48px !important;
  padding-top: 20px !important;
}

/* ── Footer ── */
.footer {
  background: rgba(5, 13, 20, .92) !important;
  border-top: 1px solid rgba(168, 217, 189, .12) !important;
  color: rgba(255, 255, 255, .88) !important;
  backdrop-filter: blur(12px) !important;
  font-family: ui-monospace, monospace !important;
  font-size: .78em !important;
  letter-spacing: .1em !important;
}
.footer a { color: rgba(255, 255, 255, .85) !important; transition: color .25s ease !important; }
.footer a:hover { color: rgba(255, 255, 255, 1) !important; text-shadow: 0 0 14px rgba(168,255,200,.6) !important; }

/* ── Links ── */
a { color: rgba(255, 255, 255, .88) !important; transition: color .25s ease !important; border-bottom: none !important; }
a:hover { color: rgba(255, 255, 255, 1) !important; text-shadow: 0 0 16px rgba(200,255,220,.5) !important; }

/* ── Blockquote ── */
blockquote {
  border-left: 2px solid rgba(169, 61, 86, .8) !important;
  background: rgba(169, 61, 86, .08) !important;
  color: rgba(255, 252, 245, .92) !important;
  border-radius: 0 12px 12px 0 !important;
  padding: 16px 24px !important;
  margin: 24px 0 !important;
  backdrop-filter: blur(8px) !important;
  font-style: normal !important;
}

/* ── Code ── */
pre, code {
  background: rgba(5, 13, 20, .8) !important;
  border: 1px solid rgba(168, 217, 189, .15) !important;
  color: rgba(255, 255, 255, .95) !important;
  border-radius: 8px !important;
  font-family: ui-monospace, SFMono-Regular, Consolas, monospace !important;
  font-size: .85em !important;
}

/* ── Scrollbar ── */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: rgba(5, 13, 20, .4) !important; }
::-webkit-scrollbar-thumb { background: rgba(168, 217, 189, .35) !important; border-radius: 999px !important; }
::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, .85) !important; }

/* ── Selection ── */
::selection { background: rgba(169, 61, 86, .5) !important; color: rgba(255, 245, 235, 1) !important; }

/* ── Buttons ── */
.btn {
  border: 1px solid rgba(168, 217, 189, .45) !important;
  color: rgba(210, 235, 220, .9) !important;
  background: rgba(10, 32, 48, .5) !important;
  border-radius: 999px !important;
  font-family: ui-monospace, monospace !important;
  font-size: .8em !important;
  letter-spacing: .14em !important;
  padding: 10px 28px !important;
  backdrop-filter: blur(10px) !important;
  transition: all .3s ease !important;
}
.btn:hover {
  border-color: rgba(200, 255, 220, .8) !important;
  color: rgba(255, 255, 255, 1) !important;
  background: rgba(168, 217, 189, .12) !important;
  box-shadow: 0 0 28px rgba(168,255,200,.25), 0 4px 16px rgba(0,0,0,.3) !important;
  transform: translateY(-2px) !important;
}

/* ── Tag Pills ── */
.post-tags a, .tag-cloud a {
  border: 1px solid rgba(169, 61, 86, .5) !important;
  color: rgba(200, 180, 160, .85) !important;
  background: rgba(169, 61, 86, .1) !important;
  border-radius: 999px !important;
  padding: 4px 14px !important;
  font-family: ui-monospace, monospace !important;
  font-size: .72em !important;
  letter-spacing: .1em !important;
  transition: all .25s ease !important;
}
.post-tags a:hover, .tag-cloud a:hover {
  background: rgba(169, 61, 86, .25) !important;
  border-color: rgba(200, 255, 220, .7) !important;
  color: rgba(255, 255, 255, 1) !important;
}

/* ── Animations ── */
@keyframes cosmicPulse {
  0%, 100% { opacity: .6; }
  50% { opacity: 1; }
}
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}
.post-block { animation: fadeInUp .6s ease both; }
.posts-collapse .post-item { animation: fadeInUp .5s ease both; }

/* ── Focus States ── */
:focus-visible {
  outline: 2px solid rgba(255, 255, 255, .85) !important;
  outline-offset: 3px !important;
  border-radius: 4px !important;
}

/* ── Sidebar / Site State (fixes 2026 etc) ── */
.site-state-item-count,
.site-state-item-name,
.collection-title,
.collection-year-count,
.sidebar .site-state-item-count,
.sidebar .site-state-item-name {
  color: rgba(255, 255, 255, .9) !important;
  background: transparent !important;
}
.site-state-item-count { color: rgba(255, 255, 255, .95) !important; font-size: 1.1em !important; }
.collection-year-count { background: rgba(168, 217, 189, .15) !important; color: rgba(255,255,255,.95) !important; border-radius: 6px !important; padding: 2px 8px !important; }
.sidebar .sidebar-inner { background: rgba(2, 12, 18, .6) !important; backdrop-filter: blur(12px) !important; }


/* ── 侧边栏作者信息 ── */
.site-author-name { color: rgba(255, 255, 255, .9) !important; }
.site-author { color: rgba(255, 255, 255, .8) !important; }
.with-love { color: rgba(255, 255, 255, .9) !important; }

/* ── 表格（专辑信息等） ── */
table { background: rgba(5, 13, 20, .7) !important; border-collapse: collapse !important; width: 100% !important; border-radius: 12px !important; overflow: hidden !important; }
th, td { color: rgba(255, 255, 255, .92) !important; padding: 12px 16px !important; border: 1px solid rgba(168, 217, 189, .15) !important; }
th { background: rgba(10, 32, 48, .8) !important; color: rgba(255, 255, 255, .97) !important; font-weight: 500 !important; letter-spacing: .1em !important; }
tr:hover td { background: rgba(168, 217, 189, .06) !important; }

/* ── 所有灰色文字 ── */
[class*="grey"], [class*="gray"], [class*="dim"], [class*="light"] {
  color: rgba(255, 255, 255, .75) !important;
}



/* ══════════════════════════════════════
   灭白底 — 所有白/浅色背景全清
══════════════════════════════════════ */

/* 强制覆盖NexT硬编码白色背景 */
.header, header, .headband,
.main, .main-inner, .column,
.site-head, .site-body,
.sidebar, .sidebar-inner, .sidebar-toggle,
.nav,
.menu, .menu-item,
.site-state, .site-state-item,
.post-button, .btn,
.pagination, .pagination-prev, .pagination-next, .page-number,
.tags, .tag, .tag-cloud,
.categories, .category,
.back-to-top,
.site-author, .site-author-name,
.footer, .footer-inner,
.powered-by,
.noscript-warning,
.site-info,
#_SCHEME_Gemini,
[class*="Gemini"],
[class*="sidebar"],
[class*="menu"],
[class*="site-state"],
[class*="post-button"] {
  background: transparent !important;
  background-color: transparent !important;
  background-image: none !important;
}

/* 具体灭白块 */
.headband { display: none !important; }
.site-state-item,
.site-state-item-count,
.site-state-item-name,
.collection-title,
.collection-year-count {
  background: rgba(10, 32, 48, .6) !important;
  border-radius: 8px !important;
  padding: 4px 12px !important;
  color: rgba(255, 255, 255, .92) !important;
}

/* 所有按钮白底黑字全清 */
.post-button,
.btn,
button,
.pagination a,
.page-number,
.tags a,
.tag a,
.categories a,
.back-to-top,
.feedback-button {
  background: rgba(10, 32, 48, .7) !important;
  background-color: rgba(10, 32, 48, .7) !important;
  color: rgba(255, 255, 255, .92) !important;
  border: 1px solid rgba(168, 217, 189, .3) !important;
  border-radius: 999px !important;
}
.post-button:hover,
.btn:hover,
button:hover,
.tags a:hover,
.tag a:hover,
.categories a:hover,
.back-to-top:hover {
  background: rgba(10, 32, 48, .9) !important;
  border-color: rgba(168, 217, 189, .6) !important;
  color: rgba(255, 255, 255, 1) !important;
}

/* 导航白底 */
.menu .menu-item a,
.menu .menu-item,
.site-nav .menu-item a {
  background: transparent !important;
  color: rgba(255, 255, 255, .82) !important;
}
.menu .menu-item a:hover {
  background: rgba(10, 32, 48, .5) !important;
  color: rgba(255, 255, 255, 1) !important;
}

/* 侧边栏透明 */
.sidebar { background: transparent !important; }
.sidebar-inner { background: rgba(5, 13, 20, .5) !important; backdrop-filter: blur(12px) !important; }

/* 底部透明 */
.footer { background: rgba(5, 13, 20, .92) !important; }
.footer-inner { background: transparent !important; }

/* 消除NexT Gemini scheme白色背景 */
.use-motion .main { background: transparent !important; }
.column { background: transparent !important; }
.main-inner { background: transparent !important; }



/* ══════════════════════════════════════
   强制覆盖所有灰色文字
══════════════════════════════════════ */

/*  blanket: 所有文字默认白色  */
* { color: rgba(255, 255, 255, .93) !important; }

/* 链接保持薄荷绿 */
a { color: rgba(168, 217, 189, .9) !important; }
a:hover { color: rgba(255, 255, 255, 1) !important; }

/* 按钮 */
.btn, button, .post-button {
  color: rgba(255, 255, 255, .92) !important;
}

/* 页脚弱化 */
.footer { color: rgba(255, 255, 255, .75) !important; }
.footer a { color: rgba(255, 255, 255, .75) !important; }

/* 元数据稍微淡一点 */
.post-meta, .site-state-item-name {
  color: rgba(255, 255, 255, .75) !important;
}

/* 引用块 */
blockquote { color: rgba(255, 255, 255, .92) !important; }

/* 代码 */
code, pre { color: rgba(168, 255, 200, .95) !important; }

/* 选中文字 */
::selection { color: rgba(255, 255, 255, 1) !important; }


/* ── 正文灰字强制白化（band/about等） ── */
.post-body,
.post-body *,
.post-body p,
.post-body div,
.post-body span,
.post-body li,
.post-body td,
.post-body th,
.post-body h2,
.post-body h3,
.post-body h4,
.post-body h5,
.post-body h6,
.posts-expand,
.posts-expand *,
.posts-expand p,
.posts-expand div,
.posts-expand span,
.posts-expand li,
.posts-expand td,
.posts-expand th,
.posts-expand h2,
.posts-expand h3,
.posts-expand h4,
.posts-expand h5,
.posts-expand h6,
.page-content,
.page-content *,
.page-content p,
.page-content div,
.page-content span,
.page-content li,
.page-content td,
.page-content th,
.page-content h2,
.page-content h3,
.page-content h4,
.page-content h5,
.page-content h6 {
  color: rgba(255, 255, 255, .95) !important;
}

.post-body a,
.posts-expand a,
.page-content a {
  color: rgba(255, 255, 255, 1) !important;
  text-decoration: underline rgba(255,255,255,.35) !important;
}



/* ── Band/About 表格：白底黑字 ── */
.post-body table,
.posts-expand table,
.page-content table {
  background: rgba(255, 255, 255, .94) !important;
  color: rgba(15, 15, 15, .95) !important;
  border: 1px solid rgba(0,0,0,.08) !important;
  border-radius: 14px !important;
  overflow: hidden !important;
}
.post-body table th,
.posts-expand table th,
.page-content table th {
  background: rgba(10, 32, 48, .92) !important;
  color: rgba(255, 255, 255, .98) !important;
  border-color: rgba(255,255,255,.08) !important;
}
.post-body table td,
.posts-expand table td,
.page-content table td {
  background: rgba(255, 255, 255, .94) !important;
  color: rgba(15, 15, 15, .95) !important;
  border-color: rgba(0,0,0,.08) !important;
}
.post-body table tr:nth-child(even) td,
.posts-expand table tr:nth-child(even) td,
.page-content table tr:nth-child(even) td {
  background: rgba(247, 249, 250, .98) !important;
  color: rgba(15, 15, 15, .95) !important;
}
.post-body table tr:hover td,
.posts-expand table tr:hover td,
.page-content table tr:hover td {
  background: rgba(232, 243, 240, .98) !important;
}


.post-body table td *,
.posts-expand table td *,
.page-content table td *,
.post-body table td strong,
.posts-expand table td strong,
.page-content table td strong {
  color: rgba(15, 15, 15, .95) !important;
}
.post-body table a,
.posts-expand table a,
.page-content table a {
  color: rgba(15, 15, 15, .95) !important;
  text-decoration: underline rgba(0,0,0,.15) !important;
}

  </style>
</body>
</html>
